#!/usr/bin/env sh

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo_root" || exit 0

# Run the fast static checks (lint + format) when the task runner is available;
# a failure blocks the commit. The slower type-check and test suite run once in
# pre-push, not here, to keep the commit loop quick. If `just` is not installed,
# skip rather than hard-failing.
if command -v just >/dev/null 2>&1; then
    just check-fast || exit 1
fi

# Optional secret scan for staged changes; a detected leak blocks the commit.
if command -v gitleaks >/dev/null 2>&1; then
    gitleaks_output=$(gitleaks git --staged --redact 2>&1)
    gitleaks_status=$?
    if [ "$gitleaks_status" -ne 0 ] && printf '%s' "$gitleaks_output" | grep -qi 'unknown command'; then
        # gitleaks < 8.19 does not have the `git` subcommand (added in 8.19);
        # that failure looks identical to a detected leak, so fall back to the
        # older `protect` subcommand instead of blocking every commit.
        gitleaks_output=$(gitleaks protect --staged --redact 2>&1)
        gitleaks_status=$?
    fi
    if [ "$gitleaks_status" -ne 0 ]; then
        printf '%s\n' "$gitleaks_output" >&2
        exit 1
    fi
fi
