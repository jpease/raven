#!/usr/bin/env sh

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo_root" || exit 0

# HEAD is resolved up front: the delete-only/no-op check below only cares
# whether any ref update is real, but the stamp check further down needs it to
# confirm the pushed ref actually is this worktree's HEAD (see refs_match_head).
head_sha=$(git rev-parse HEAD 2>/dev/null)

# Git feeds the push plan on stdin as "<local-ref> <local-sha> <remote-ref>
# <remote-sha>" lines; a deletion has an all-zero local-sha. If every line is a
# deletion (or stdin is empty), no code is leaving the machine, so skip the
# expensive gate. Git already short-circuits a fully up-to-date push before the
# hook runs, so this only adds coverage for delete-only pushes. The `case` glob
# treats a SHA as real work iff it holds any non-zero character, which keeps this
# free of external commands (no `tr`) and agnostic to SHA-1 vs SHA-256 length.
#
# refs_match_head also tracks whether every pushed local-sha equals head_sha.
# The stamp only proves that *this* worktree's checked-out HEAD passed `just
# check`; it says nothing about a different commit being pushed (a different
# branch than the one checked out here, or a commit made in another worktree
# sharing this git dir). Without this check, a stamped worktree on `main`
# could rubber-stamp `git push origin feature` with zero checks run
# (issue #80).
has_work=0
refs_match_head=1
while read -r _local_ref local_sha _remote_ref _remote_sha; do
    case "$local_sha" in
        "") ;;             # blank line, ignore
        *[!0]*)            # contains a non-zero digit -> a real ref update
            has_work=1
            [ "$local_sha" = "$head_sha" ] || refs_match_head=0
            ;;
    esac
done
[ "$has_work" -eq 0 ] && exit 0

# Block AI-authorship credits in outbound commit content (an AI tool named as
# the generator, left in a source file). Independent of the check-passed
# stamp below, since that stamp only vouches for `just check` having passed,
# not content. Skip if the lib script is missing (a stale/partial install)
# rather than hard-failing.
attribution_check="$repo_root/.raven/git-hooks/lib/check-ai-attribution-content.py"
if [ -f "$attribution_check" ]; then
    python3 "$attribution_check" outbound || exit 1
fi

# The gate runs against the working tree, so a commit is only safely "already
# verified" if the tree is also clean and every pushed ref is this worktree's
# HEAD (see refs_match_head above). The stamp records the HEAD SHA that last
# passed `just check` with a clean tree -- written either by this hook below,
# or by the `check` recipe itself when it is run manually (see
# lib/stamp-verified.sh); the skip invariant is the same either way, so a
# manual run earns the same credit. If HEAD still matches, every pushed
# ref is that HEAD, and the tree is still clean, re-running is pure waste. A
# new commit, amend, or any uncommitted change alters HEAD or dirties the
# tree and invalidates the stamp; pushing a ref other than HEAD falls back to
# running the gate too, same as before the stamp existed for that case. That
# fallback still only checks the working tree, not the pushed ref's actual
# content, so it does not fully verify e.g. a cross-worktree push of a
# different branch -- closing that would require checking out the pushed
# ref, which this hook intentionally does not do. A second, unrelated gap the
# working-tree design cannot close either: committing broken code and then
# fixing it locally without committing lets `just check` pass against the
# fixed tree while HEAD (the broken commit) is what actually gets pushed. The
# stamp lives in the (per-worktree) git dir, so it is never committed and is
# wiped on re-clone. A missing or unreadable stamp simply falls through to
# the gate.
stamp="$(git rev-parse --git-dir)/raven-pre-push-verified"
if [ -n "$head_sha" ] && [ "$refs_match_head" -eq 1 ] \
    && [ -z "$(git status --porcelain 2>/dev/null)" ] \
    && [ "$head_sha" = "$(cat "$stamp" 2>/dev/null)" ]; then
    exit 0
fi

# Run the full verification set (lint, format, type-check, tests) before code
# leaves the machine; a failure blocks the push. pre-commit already ran the fast
# subset, so the only heavy work added here is the type-check and test suite --
# tests run exactly once across both hooks. Re-running the fast checks is the
# cheap last line of defense against commits made with `--no-verify`. If `just`
# is not installed, skip rather than hard-failing.
if command -v just >/dev/null 2>&1; then
    just check || exit 1
    # Record the verified commit only when the tree is still clean, so a cached
    # pass can never vouch for uncommitted work. If the gate dirtied the tree
    # (e.g. build artifacts), skip stamping this run rather than caching a lie.
    # Shared with the `check` recipe so a manual `just check` run gets credited
    # identically; the script re-derives head_sha/stamp itself and swallows
    # its own failures, since the stamp is an optimization, not a gate.
    sh "$repo_root/.raven/git-hooks/lib/stamp-verified.sh" 2>/dev/null || true
fi
