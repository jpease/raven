# Run the test suite
test:
    swift test

# Run lint checks
lint:
    swiftlint lint

# Format the codebase (Apple swift-format via the Xcode toolchain; tracked source only)
format:
    git ls-files -z '*.swift' | xargs -0 xcrun swift-format format --parallel --in-place

# Verify formatting without modifying files (CI-friendly; exits non-zero on drift)
lint-format:
    git ls-files -z '*.swift' | xargs -0 xcrun swift-format lint --parallel --strict

# Build the project
build:
    swift build

# Run the standard local verification set
check: lint-format lint build test

# Install a pre-commit git hook that runs 'just check'
install-hooks:
    #!/usr/bin/env sh
    if [ -f .git/hooks/pre-commit ]; then
        echo "A pre-commit hook already exists at .git/hooks/pre-commit."
        echo "To use RAVEN's check, add this line to it:"
        printf "  just check\n"
    else
        mkdir -p .git/hooks
        printf '#!/bin/sh\njust check\n' > .git/hooks/pre-commit
        chmod +x .git/hooks/pre-commit
        echo "Installed .git/hooks/pre-commit to run 'just check' before each commit."
    fi
