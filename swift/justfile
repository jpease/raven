# Xcode app targets only (ignored for SwiftPM packages). Set SCHEME to your
# Xcode scheme -- for xcodegen projects this is the `name:` in project.yml.
SCHEME := "YourScheme"
DESTINATION := "platform=iOS Simulator,name=iPhone 16"

# Run the test suite: SwiftPM package -> `swift test`; Xcode app -> `xcodebuild`.
test:
    #!/usr/bin/env sh
    if [ -f Package.swift ]; then
        swift test
    else
        xcodebuild -scheme "{{SCHEME}}" test -destination "{{DESTINATION}}"
    fi

# Run lint checks
lint:
    swiftlint lint

# Format the codebase (Apple swift-format via the Xcode toolchain; tracked source only)
format:
    git ls-files -z '*.swift' | xargs -0 xcrun swift-format format --parallel --in-place

# Verify formatting without modifying files (CI-friendly; exits non-zero on drift)
lint-format:
    git ls-files -z '*.swift' | xargs -0 xcrun swift-format lint --parallel --strict

# Build: SwiftPM package -> `swift build`; Xcode app -> `xcodebuild`.
build:
    #!/usr/bin/env sh
    if [ -f Package.swift ]; then
        swift build
    else
        xcodebuild -scheme "{{SCHEME}}" build -destination "{{DESTINATION}}"
    fi

# Fast static checks for the pre-commit hook (no build, no tests)
check-fast: lint-format lint

# Run the standard local verification set (also runs in the pre-push hook).
# `build` catches compile breaks; `test` is on-demand / CI -- an Xcode app's UI
# test suite is too heavy for every push. SwiftPM projects can add `test` here.
check: check-fast build

# Install pre-commit (fast checks) and pre-push (full check) git hooks
install-hooks:
    #!/usr/bin/env sh
    # Resolve Git's effective hooks dir (honors core.hooksPath and linked
    # worktrees) so hooks land where Git will run them, not a hard-coded
    # .git/hooks that a custom hooksPath would ignore.
    hooks_dir=$(git rev-parse --git-path hooks) || exit 1
    install_hook() {
        name="$1"
        cmd="$2"
        path="$hooks_dir/$name"
        if [ -f "$path" ]; then
            echo "A $name hook already exists at $path."
            echo "To use RAVEN's gate, add this line to it:"
            printf "  %s\n" "$cmd"
        else
            mkdir -p "$hooks_dir"
            printf '#!/bin/sh\n%s\n' "$cmd" > "$path"
            chmod +x "$path"
            echo "Installed $path to run '$cmd'."
        fi
    }
    install_hook pre-commit "just check-fast"
    install_hook pre-push "just check"
