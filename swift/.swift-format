{
  "version": 1,
  "lineLength": 100,
  "indentation": {
    "spaces": 4
  },
  "rules": {
    "UseTripleSlashForDocumentationComments": false,
    "ReplaceForEachWithForLoop": false,
    "AlwaysUseLowerCamelCase": false,
    "NoBlockComments": false,
    "AvoidRetroactiveConformances": false,
    "AmbiguousTrailingClosureOverload": false
  }
}
