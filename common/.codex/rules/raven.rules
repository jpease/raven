# RAVEN command approval rules for Codex.
#
# Codex rules are experimental. These rules complement hook-based guardrails;
# hooks remain the stronger enforcement layer for contextual checks.

prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Refusing destructive deletion of the filesystem root.",
    match = ["rm -rf /"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "Hard reset can discard local work; require explicit approval.",
    match = ["git reset --hard", "git reset --hard HEAD"],
)

prefix_rule(
    pattern = ["git", "clean", "-fdx"],
    decision = "prompt",
    justification = "git clean -fdx can remove untracked work and generated state; require explicit approval.",
    match = ["git clean -fdx"],
)

prefix_rule(
    pattern = ["kubectl", "delete"],
    decision = "prompt",
    justification = "Kubernetes deletion can affect live resources; require explicit approval.",
    match = ["kubectl delete pod example"],
)

prefix_rule(
    pattern = ["dropdb"],
    decision = "prompt",
    justification = "Database deletion requires explicit approval.",
    match = ["dropdb app_development"],
)
