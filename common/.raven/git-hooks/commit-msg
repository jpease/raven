#!/usr/bin/env python3
"""commit-msg hook: strip AI agent attribution trailers before they land in git history."""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

# Match Co-Authored-By or Generated-by trailers that name a known AI tool or AI provider domain.
_AI_TRAILER = re.compile(
    r"^(?:co-authored-by|generated-by):\s+.*"
    r"(?:claude|copilot|codex|chatgpt|gpt-[0-9]+|gemini|llama|mistral"
    r"|@anthropic\.com|@openai\.com)",
    re.IGNORECASE,
)

# Minimal TOML scan: find a boolean key inside a named section.
_SECTION_RE = re.compile(r"^\s*\[([^\]]+)\]")
_BOOL_RE = re.compile(r"^\s*(\w+)\s*=\s*(true|false)\b", re.IGNORECASE)


def _read_config_bool(config_path: Path, section: str, key: str, default: bool) -> bool:
    if not config_path.exists():
        return default
    in_section = False
    for line in config_path.read_text(encoding="utf-8").splitlines():
        m = _SECTION_RE.match(line)
        if m:
            in_section = m.group(1).strip() == section
            continue
        if in_section:
            m = _BOOL_RE.match(line)
            if m and m.group(1) == key:
                return m.group(2).lower() == "true"
    return default


def _repo_root() -> Path | None:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        )
        return Path(result.stdout.strip())
    except subprocess.CalledProcessError:
        return None


def main() -> int:
    root = _repo_root()
    if root is not None:
        config = root / ".raven" / "config.toml"
        if not _read_config_bool(config, "git_hooks", "strip_ai_attribution", default=True):
            return 0

    msg_file = Path(sys.argv[1])
    lines = msg_file.read_text(encoding="utf-8").splitlines()

    cleaned = [line for line in lines if not _AI_TRAILER.match(line)]
    while cleaned and not cleaned[-1].strip():
        cleaned.pop()

    if cleaned != lines:
        removed = [line for line in lines if line not in cleaned]
        msg_file.write_text("\n".join(cleaned) + "\n", encoding="utf-8")
        for trailer in removed:
            print(f"raven commit-msg: removed AI attribution: {trailer}", file=sys.stderr)

    return 0


if __name__ == "__main__":
    sys.exit(main())
