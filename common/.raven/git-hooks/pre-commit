#!/usr/bin/env sh

# Optional secret scan for staged changes. If Gitleaks is not installed, Raven
# leaves the commit path alone instead of making the hook a hard dependency.
if ! command -v gitleaks >/dev/null 2>&1; then
    exit 0
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo_root" || exit 0

gitleaks git --staged --redact
